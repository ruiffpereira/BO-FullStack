{
  "name": "backoffice",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Backoffice multi-negócio — React + Vite + TypeScript + TailwindCSS + React Query (Kubb)",
  "scripts": {
    "dev": "kubb generate && vite",
    "build": "kubb generate && tsc -b && vite build && node scripts/write-version.mjs",
    "preview": "vite preview",
    "kubb": "kubb generate",
    "kubb:refresh": "node scripts/kubb-refresh.mjs",
    "lint": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright test --reporter=html"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.62.7",
    "@tiptap/extension-color": "^3.26.1",
    "@tiptap/extension-link": "^3.26.1",
    "@tiptap/extension-table": "^3.26.1",
    "@tiptap/extension-table-cell": "^3.26.1",
    "@tiptap/extension-table-header": "^3.26.1",
    "@tiptap/extension-table-row": "^3.26.1",
    "@tiptap/extension-text-align": "^3.26.1",
    "@tiptap/extension-text-style": "^3.26.1",
    "@tiptap/extension-underline": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "axios": "^1.7.9",
    "country-flag-icons": "^1.6.17",
    "date-fns": "^4.1.0",
    "react": "^18.3.1",
    "react-day-picker": "^10.0.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.17.0",
    "sonner": "^1.7.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@kubb/cli": "^3.0.0",
    "@kubb/core": "^3.0.0",
    "@kubb/plugin-client": "^3.0.0",
    "@kubb/plugin-oas": "^3.0.0",
    "@kubb/plugin-react-query": "^3.0.0",
    "@kubb/plugin-ts": "^3.0.0",
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
